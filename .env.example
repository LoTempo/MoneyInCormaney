APP_ENV=development
SECRET_KEY=replace-this-with-a-random-secret-key

# Neon: pooled-адрес с -pooler для обычной работы приложения.
# Не помещайте настоящий пароль в Git.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require

# Neon: прямой адрес без -pooler только для команды init-db.
# После создания таблиц на рабочем сервере эту переменную можно не хранить.
DATABASE_ADMIN_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT.REGION.aws.neon.tech/DATABASE?sslmode=require&channel_binding=require

# Параметры ниже используются, только если DATABASE_URL не задан.
# Они удобны для локального PostgreSQL.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=family_budget
DATABASE_USER=family_budget_user
DATABASE_PASSWORD=replace-this-with-the-database-password
DATABASE_CONNECT_TIMEOUT=5
DATABASE_POOL_MIN_SIZE=0
DATABASE_POOL_MAX_SIZE=5
DATABASE_POOL_MAX_IDLE=240
FLASK_DEBUG=true
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
