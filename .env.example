APP_ENV=development
SECRET_KEY=replace-this-with-a-random-secret-key

# Необязательная полная строка подключения к PostgreSQL.
# Она подходит для облачной базы, VPS или локального PostgreSQL.
# Оставьте значение пустым, чтобы использовать параметры DATABASE_HOST и другие ниже.
# Пример: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Не помещайте настоящий адрес с паролем в Git.
DATABASE_URL=

# Необязательная отдельная строка для создания таблиц командой init-db.
# Она нужна только тогда, когда облачный провайдер выдает разные адреса:
# pooled для приложения и direct/admin для административных команд.
# В остальных случаях оставьте значение пустым.
DATABASE_ADMIN_URL=

# Эти параметры используются, только если DATABASE_URL оставлен пустым.
# Значения по умолчанию рассчитаны на PostgreSQL на этом же компьютере.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=family_budget
DATABASE_USER=family_budget_user
DATABASE_PASSWORD=replace-this-with-the-database-password
DATABASE_CONNECT_TIMEOUT=5
DATABASE_POOL_MIN_SIZE=0
DATABASE_POOL_MAX_SIZE=5
DATABASE_POOL_MAX_IDLE=240
FLASK_DEBUG=true
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
